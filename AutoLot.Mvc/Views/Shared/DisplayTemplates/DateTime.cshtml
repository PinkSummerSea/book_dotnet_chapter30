    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model DateTime?
@if(Model == null){
    @: Unknown
}
else {
    if(ViewData.ModelMetadata.IsNullableValueType){
        @:@(Model.Value.ToString("d"))
    }else{
        @:@(((DateTime)Model).ToString("d"))
    }
}
