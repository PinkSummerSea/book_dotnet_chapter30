@model AutoLot.Models.Entities.Car
@{
    ViewData["Title"]="RazorSyntax";
}
<h1>Razor Syntax</h1>

@{
    var foo = "Foo";
    var bar = "Bar";
    var htmlString = "<ul><li>one</li><li>two</li></ul>";
    @: Plain text here<br/>
    <h2>haha</h2>
}

@foo<br />
@htmlString<br />
@foo.@bar<br/>
@foo.ToUpper()
@Html.Raw(htmlString)
<hr />
<p>The Car named @Model.PetName is a <span style="color:@Model.Color">@Model.Color</span> @Model.MakeNavigation.Name</p>
